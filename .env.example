# Riot API key personal (https://developer.riotgames.com/). No la expongas en el frontend.
RIOT_API_KEY=

# Región de plataforma para Riot API (ej: la1, na1, euw1)
RIOT_PLATFORM=la1
# Región de routing para match-v5 (americas, asia, europe)
RIOT_REGION=americas

# Locale de Data Dragon para nombres de campeones (es_MX, es_ES, en_US, …)
DDRAGON_LOCALE=es_MX

# Puerto del backend local
PORT=3535
